# Database Credentials
# db is "db" running on port localhost/5050 for pgadmin db management
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

DB_PORT=5432
PGADMIN_EMAIL=postgres@admin.com
PGADMIN_PASSWORD=postgres@admin.com

# URL สำหรับเชื่อมต่อกับฐานข้อมูล PostgreSQL ที่รันอยู่ใน Docker
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres

# Secret Key สำหรับเข้ารหัส Session Middleware (จำเป็นสำหรับ Google OAuth)
SECRET_KEY=a-very-secret-key-for-sessions-12345

#ไว้เทส noti เป็น development ถ้าใช้งานจริงคือ production
APP_ENV=development
FRONTEND_PORT=3000
BACKEND_PORT=8080

# Credentials ที่ได้จาก Google Cloud Console สำหรับทำ Google Login
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_CALLBACK_FRONTEND_URL=http://localhost:3000

# SENDER_EMAIL Email ทั่วไปของผู้ใช้
SENDER_EMAIL=your_email@example.com
# สร้าง Appplication Password ของบัญชี Email เพื่อใช้ส่งอีเมลผ่าน SMTP โดยไม่ต้องใช้รหัสผ่านจริงของบัญชี Gmail
SENDER_PASSWORD=your_app_password_here